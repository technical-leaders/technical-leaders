# SEObot CMS Configuration
VITE_SEOBOT_API_KEY=your_seobot_api_key_here

# Stripe API key used by all /api/stripe/* serverless endpoints
STRIPE_SECRET_KEY=sk_live_or_test_key_here

# Stripe product ID that gates /claude-workshop-replay.
# The page unlocks when the visitor's email matches a completed purchase of
# this product (one-time payment via the Stripe Payment Link, or an active
# subscription). Falls back to the literal default in
# api/stripe/workshop-verify-email.ts if unset. The live Payment Link currently
# sells this product ("The AI Workshop").
# IMPORTANT: set this in the Vercel project env (Production) so a future product
# swap doesn't require a code change. If it is set to the WRONG id, every
# lookup fails closed and buyers are locked out.
WORKSHOP_REPLAY_PRODUCT_ID=prod_UEOF7uxtQvH8MB

# Optional: pin the workshop Stripe Payment Link id (plink_...). When set, the
# verify endpoint scopes its completed-session scan to this link instead of
# resolving it from the public buy.stripe.com URL on each request. Leave unset
# to auto-resolve.
# WORKSHOP_REPLAY_PAYMENT_LINK_ID=plink_xxx

# Kit.com (ConvertKit) API secret used by /api/office-hours/verify-email to
# confirm an email is an active subscriber (the free-signup gate for the
# office-hours second half + library). Find it in the Kit account under
# Settings → Advanced → API. If unset, the office-hours gate fails closed and
# denies access. Set this in the Vercel project env (Production).
CONVERTKIT_API_SECRET=your_convertkit_api_secret_here

# Office-hours ingestion (scripts/transcribe-office-hours.mjs).
# The ingestion step pulls the AI Office Hours "Interactions" from Airtable and
# exports each session's Google-Doc transcript to text, then segments + scrubs it.
#
# AIRTABLE_API_KEY: a personal access token (Bearer) with read scope on base
# appISrtODYeSTN5Lb (table Interactions). Sent as `Authorization: Bearer <key>`
# on the Airtable REST calls. Find/create it at https://airtable.com/create/tokens.
# AIRTABLE_API_KEY=pat_xxx
#
# Google Drive export auth (transcript Docs → text via
# drive/v3/files/<id>/export). The PREFERRED path is a Google service account
# with read access to the Docs; the script signs a short-lived RS256 JWT with the
# key below and exchanges it at https://oauth2.googleapis.com/token for a
# drive.readonly access token at build time (no JWT library — Node's built-in
# crypto). Set BOTH of these in the Vercel project env:
#
# GOOGLE_SERVICE_ACCOUNT_EMAIL: the service account's client_email.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=my-sa@my-project.iam.gserviceaccount.com
#
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY: the service account's PEM private_key. When
# stored in a single-line env var the newlines are usually escaped as literal
# `\n`; the script turns those back into real newlines, so you can paste the
# escaped form directly. Keep the BEGIN/END PRIVATE KEY markers.
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# GOOGLE_DRIVE_ACCESS_TOKEN (legacy/optional): a pre-minted Drive OAuth access
# token. Only used when the service-account vars above are NOT set; prefer the
# service account so tokens are minted fresh at build time.
# GOOGLE_DRIVE_ACCESS_TOKEN=ya29.xxx
#
# NOTE: in the Claude build environment api.airtable.com and *.googleapis.com are
# proxy-injected, so ingestion runs keyless there (all the vars above may be
# absent). At Vercel the proxy is absent and these creds refresh the transcripts;
# if they are missing/invalid the script DEGRADES GRACEFULLY — it logs a warning
# and keeps the committed, already scrubbed transcript artifacts, so
# `npm run build` still succeeds.
#
# OFFICE_HOURS_SINCE: optional ISO date lower bound (YYYY-MM-DD). Only sessions
# on/after it are ingested. Defaults to 2026-02-01 (the start of the published
# YouTube library); set a later date to ingest only recent sessions.
# OFFICE_HOURS_SINCE=2026-02-01

# Other environment variables
# Add other environment variables as needed
